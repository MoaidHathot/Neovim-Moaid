{
	"$schema": "https://opencode.ai/config.json",
	"provider": {
		"github-copilot": {
			"models": {
				"claude-opus-4.7-1m": {
					"variants": {
						"low": {
							"reasoningEffort": "low"
						},
						"medium": {
							"reasoningEffort": "medium"
						},
						"high": {
							"reasoningEffort": "high"
						}
					}
				}
			}
		}
	},
	"lsp": {
		"json": {
			"command": [
				"vscode-json-language-server",
				"--stdio"
			],
			"extensions": [
				".json",
				".jsonc"
			]
		},
		"marksman": {
			"command": [
				"marksman",
				"server"
			],
			"extensions": [
				".md",
				".markdown"
			]
		},
		"powershell": {
			"command": [
				"pwsh",
				"-NoLogo",
				"-NoProfile",
				"-Command",
				"$pses=(Get-Module -ListAvailable PowerShellEditorServices|Sort-Object Version -Descending|Select-Object -First 1).ModuleBase; & \"$pses/Start-EditorServices.ps1\" -BundledModulesPath (Split-Path $pses -Parent) -LogPath \"$env:TEMP/opencode-pses.log\" -SessionDetailsPath \"$env:TEMP/opencode-pses-session.json\" -FeatureFlags @() -AdditionalModules @() -HostName opencode -HostProfileId opencode -HostVersion 1.0.0 -Stdio"
			],
			"extensions": [
				".ps1",
				".psm1",
				".psd1"
			]
		},
		"taplo": {
			"command": [
				"taplo",
				"lsp",
				"stdio"
			],
			"extensions": [
				".toml"
			]
		}
	},
	"mcp": {
		"teams": {
			"enabled": false,
			"type": "remote",
			"url": "https://agent365.svc.cloud.microsoft/agents/tenants/72f988bf-86f1-41af-91ab-2d7cd011db47/servers/mcp_TeamsServer"
		},
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp"
		},
		"zakira-recall": {
			"type": "local",
			"command": [
				"dnx",
				"Zakira.Recall",
				"--yes",
				"--",
				"mcp"
			]
		},
		"zakira-replay": {
			"type": "local",
			"command": [
				"dnx",
				"Zakira.Replay",
				"--yes",
				"--",
				"mcp",
				"serve"
			]
		},
		"ev2": {
			"enabled": false,
			"type": "local",
			"command": [
				"pwsh",
				"-NoProfile",
				"-Command",
				"Push-Location 'P:\\Work\\Networking\\Repo\\ev2-mcp\\src\\mcp\\ev2\\ev2mcp'; dotnet run; Pop-Location"
			]
		},
		"azure": {
			"enabled": false,
			"type": "local",
			"command": [
				"pwsh",
				"-NoProfile",
				"-Command",
				"Push-Location $env:TEMP; dnx Azure.Mcp --yes -- azmcp server start; Pop-Location"
			]
		},
		"azdo": {
			"enabled": false,
			"type": "local",
			"command": [
				"pwsh",
				"-NoProfile",
				"-Command",
				"Push-Location $env:TEMP; npx -y @azure-devops/mcp msazure; Pop-Location"
			]
		},
		"dtfx": {
			"enabled": false,
			"type": "local",
			"command": [
				"pwsh",
				"-NoProfile",
				"-Command",
				"Push-Location 'P:\\Playground\\DurableTasksMcp'; dotnet run -- -s ztsdevlndt; Pop-Location"
			]
		},
		"teams-proxy-local": {
			"type": "local",
			"command": [
				"dotnet",
				"run",
				"--project",
				"P:\\Github\\mcp-proxy\\samples\\15-teams-integration\\",
				"--",
				"--tenant-id=72f988bf-86f1-41af-91ab-2d7cd011db47",
				"--auth-mode=user-auth",
				"--vscode-client-id=aebc6443-996d-45c2-90f0-388ff96faa56"
			],
			"enabled": false,
			"timeout": 90000
		}
	}
}
