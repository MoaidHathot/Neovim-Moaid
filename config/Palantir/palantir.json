{
  "paths": {
    "cache": "${LOCALAPPDATA}/Palantir/cache"
  },
  "personalities": {
    "opencode": {
      "displayName": "OpenCode",
      "icon": "https://opencode.ai/apple-touch-icon.png"
    }
  },
  "presets": {
    "opencode-idle": {
      "personality": "opencode",
      "expandShortcodes": true,
      "title": "✅ Task complete",
      "audio": "default",
      "duration": "short"
    },
    "opencode-error": {
      "personality": "opencode",
      "expandShortcodes": true,
      "title": "❌ Session error",
      "audio": "alarm2",
      "duration": "short",
      "scenario": "reminder"
    },
    "opencode-permission": {
      "personality": "opencode",
      "expandShortcodes": true,
      "title": "❓ Approval needed",
      "audio": "reminder",
      "duration": "short",
      "scenario": "reminder"
    }
  }
}
