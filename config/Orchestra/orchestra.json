{
	"dataPath": null,
	"urls": "http://127.0.0.1:5100",
	"hostBaseUrl": "http://localhost:5100",
	"defaultModel": "gpt-5.4",
	"scan": {
		"directory": "./workspace/",
		"watch": true,
		"recursive": true
	},
	"shutdownTimeoutSeconds": 30,
	"logLevel": "Debug",
	"retention": {
		"maxRunsPerOrchestration": 0,
		"maxRunAgeDays": 0
	},
	"polling": {
		"activeExecutionsMs": 2000,
		"orchestrationsMs": 2000,
		"historyMs": 5000,
		"serverStatusMs": 5000
	},
	"mcpServer": {
		"dataPlaneEnabled": true,
		"dataPlaneRoute": "/mcp/data",
		"controlPlaneEnabled": false,
		"controlPlaneRoute": "/mcp/control",
		"maxNestingDepth": 5
	}
}
