{
	"dataPath": null,
	"urls": "http://127.0.0.1:5100",
	"hostBaseUrl": "http://localhost:5100",
	"defaultModel": "gpt-5.4",
	"agentPool": {
		"minInstances": 1,
		"maxInstances": 70,
		"maxSessionsPerInstance": 3,
		"idleTimeoutSeconds": 120
	},
	"scan": {
		"directory": "./workspace/",
		"watch": true,
		"recursive": true
	},
	"autoResumeCheckpointsOnStartup": true,
	"shutdownTimeoutSeconds": 30,
	"logLevel": "Debug",
	"retention": {
		"maxRunsPerOrchestration": 0,
		"maxRunAgeDays": 0
	},
	"polling": {
		"activeExecutionsMs": 2000,
		"orchestrationsMs": 2000,
		"historyMs": 5000,
		"serverStatusMs": 5000
	},
	"mcpServer": {
		"dataPlaneEnabled": true,
		"dataPlaneRoute": "/mcp/data",
		"controlPlaneEnabled": false,
		"controlPlaneRoute": "/mcp/control",
		"maxNestingDepth": 5,
		"defaultOrchestraInvokeTimeoutSeconds": 86400
	},
	"sse": {
		"maxAccumulatedEvents": 500000,
		"maxChannelCapacity": 50000,
		"maxSubscribers": 100,
		"heartbeatIntervalSeconds": 20
	}
}
