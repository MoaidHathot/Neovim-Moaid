{
	"dataPath": null,
	"hostBaseUrl": "http://localhost:5200",
	"defaultModel": "claude-opus-4.6",
	"scan": {
		"directory": "./Config/Orchestrations/",
		"watch": false,
		"recursive": false
	},
	"shutdownTimeoutSeconds": 30,
	"logLevel": "Debug",
	"retention": {
		"maxRunsPerOrchestration": 0,
		"maxRunAgeDays": 0
	},
	"polling": {
		"activeExecutionsMs": 2000,
		"orchestrationsMs": 2000,
		"historyMs": 5000,
		"serverStatusMs": 5000
	},
	"mcpServer": {
		"dataPlaneEnabled": true,
		"dataPlaneRoute": "/mcp/data",
		"controlPlaneEnabled": false,
		"controlPlaneRoute": "/mcp/control",
		"maxNestingDepth": 5
	}
}
