{
  "services": [
    {
      "name": "m365-remote-mcps",
      "type": "process",
      "command": "dnx",
      "arguments": ["mcpproxy", "--yes", "--", "-t", "http", "-c", "${XDG_CONFIG_HOME}/orchestra/m365.proxy.json", "-p", "5113"],
      "required": true,
      "shutdownTimeoutSeconds": 5,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Production"
      },
      "readiness": {
        "stdoutPattern": "Now listening on",
        "healthCheckUrl": "http://localhost:5113/mcp",
        "timeoutSeconds": 10
      }
    }
  ]
}

