{
	"services": [
		{
			"name": "m365-remote-mcps",
			"type": "process",
			"command": "dnx",
			"arguments": [
				"mcpproxy",
				"--yes",
				"--",
				"-t",
				"http",
				"-c",
				"${XDG_CONFIG_HOME}/orchestra/m365.proxy.json",
				"-p",
				"5113"
			],
			"required": true,
			"forceKill": true,
			"env": {
				"ASPNETCORE_ENVIRONMENT": "Production"
			},
			"readiness": {
				"stdoutPattern": "Now listening on",
				"healthCheckUrl": "http://localhost:5113/mcp",
				"timeoutSeconds": 3
			}
		},
		{
			"name": "ActionView",
			"type": "process",
			"command": "dnx",
			"arguments": [
				"ActionView.Api",
				"--yes"
			],
			"required": false,
			"forceKill": true,
			"readiness": {
				"stdoutPattern": "Now listening on",
				"timeoutSeconds": 3
			}
		}
	]
}
