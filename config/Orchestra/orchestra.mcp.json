{
	"mcps": [
		{
			"name": "calendar",
			"type": "Remote",
			"endpoint": "http://localhost:5113/mcp/calendar"
		},
		{
			"name": "mail",
			"type": "Remote",
			"endpoint": "http://localhost:5113/mcp/mail"
		},
		{
			"name": "m365-copilot",
			"type": "Remote",
			"endpoint": "http://localhost:5113/mcp/m365-copilot"
		},
		{
			"name": "me",
			"type": "Remote",
			"endpoint": "http://localhost:5113/mcp/me"
		},
		{
			"name": "icm-full",
			"type": "local",
			"command": "dnx",
			"arguments": [
				"IcM.Mcp",
				"--source",
				"https://pkgs.dev.azure.com/msazure/One/_packaging/ZTS/nuget/v3/index.json",
				"--yes"
			]
		},
		{
			"name": "icm-readonly",
			"type": "local",
			"command": "dnx",
			"arguments": [
				"IcM.Mcp",
				"--source",
				"https://pkgs.dev.azure.com/msazure/One/_packaging/ZTS/nuget/v3/index.json",
				"--yes",
				"--",
				"--read-only"
			]
		},
		{
			"name": "azdo",
			"type": "local",
			"command": "npx",
			"arguments": [
				"-y",
				"@azure-devops/mcp",
				"msazure"
			]
		},
		{
			"name": "azure",
			"type": "local",
			"command": "dnx",
			"arguments": [
				"Azure.Mcp",
				"--yes",
				"--",
				"azmcp",
				"server",
				"start"
			]
		},
		{
			"name": "powerreview",
			"type": "local",
			"command": "dnx",
			"arguments": [
				"--yes",
				"PowerReview",
				"--",
				"mcp"
			]
		},
		{
			"name": "debug-mcp",
			"type": "local",
			"command": "dotnet",
			"arguments": [
				"run",
				"--file",
				"P:\\Github\\Orchestra\\playground\\mcp\\McpDebug.cs"
			]
		},
		{
      "name": "teams",
			"type": "local",
      "command": "dnx",
      "arguments": [
        "McpProxy.Samples.Teams.Mcp",
        "--yes",
        "--",
        "--auth-mode=user-auth",
        "--tenant-id=${CORP_TENANT_ID}",
        "--public-client-id=${VSCODE_CLIENT_ID}",
        "--token-cache-name=mcp-proxy"
      ],
      "environment": {
        "AZURE_SCOPES": "${VSCODE_AUDIENCE}/.default"
      },
      "enabled": true
    },
		{
			"name": "playwright",
			"type": "local",
			"command": "npx",
			"arguments": [
				"--yes",
				"--registry=https://registry.npmjs.org/",
				"@playwright/mcp@latest",
				"--headless",
				"--browser=msedge"
			]
		}
	]
}
